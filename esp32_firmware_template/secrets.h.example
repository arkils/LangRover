/**
 * WiFi credentials for OTA firmware updates.
 *
 * HOW TO USE:
 *   1. Copy this file:  secrets.h.example  →  secrets.h
 *   2. Fill in your network name and password below
 *   3. Upload the sketch via Arduino IDE
 *
 * secrets.h is gitignored — your real credentials will never be committed.
 * Leave WIFI_SSID as "" to skip Wi-Fi/OTA entirely (USB-only operation).
 */

#define WIFI_SSID      ""   // e.g. "MyHomeNetwork"
#define WIFI_PASSWORD  ""   // e.g. "MyPassword123"
#define OTA_PASSWORD   ""   // e.g. "langrover" — leave empty to skip OTA password prompt
