# LangRover Environment Configuration Template
# Copy this to .env and fill in your values
# .env is in .gitignore and won't be committed

# ===== LLM Provider Settings =====
# Options: "openai" or "ollama"
# Default: ollama (local, no API key needed)
LLM_PROVIDER=ollama

# OpenAI Configuration (only needed if using openai provider)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Ollama Configuration (required if using ollama provider)
# Ollama Base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model Name (default: qwen2.5:0.5b)
# qwen2.5:0.5b supports tool calling and runs on low-memory hardware
# Available models: run 'ollama list' to see installed models
OLLAMA_MODEL=qwen2.5:0.5b

# ===== Simulation Settings =====
# Number of decision cycles to run
SIMULATION_STEPS=10

# Seconds to wait between decision cycles
DECISION_CYCLE_DELAY=1

# Verbose agent output (true/false)
VERBOSE=true
