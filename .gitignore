# Git exclusions for LangRover

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Arduino WiFi credentials — never commit
esp32_firmware/secrets.h

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log

# ML model weights (auto-downloaded at runtime, not stored in repo)
*.pt
*.onnx
*.tflite
*.gguf
runs/

# Streamlit UI — runtime camera frames
ui/temp/

# ChromaDB — auto-populated vector stores (not stored in repo)
chroma_db/
chroma_rag/
